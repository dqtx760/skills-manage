#!/usr/bin/env python3
"""Social-SBTI CLI shim.

This file is a trivial loader so callers can do:
    bash "$SBTI_HOME/bin/sbti" doctor
    "$SBTI_HOME/bin/sbti" doctor          # also fine if it's executable
    python3 "$SBTI_HOME/bin/sbti" doctor  # ditto

The real implementation lives in ../src/cli.py.
"""
from __future__ import annotations

import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
SRC = HERE.parent / "src"
sys.path.insert(0, str(SRC))

from cli import main  # type: ignore  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
